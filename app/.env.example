# MT5 Trading Bot Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# CORE DJANGO SETTINGS
# =============================================================================
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,*.defang.dev

# CSRF trusted origins (comma-separated)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://*.defang.dev

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
USE_POSTGRES=False
DB_NAME=mt5_trading_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
USE_REDIS=False
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# MT5 CONNECTION SETTINGS
# =============================================================================
MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password
MT5_SERVER=MetaQuotes-Demo
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_TIMEOUT=60000
MT5_PORTABLE=False

# =============================================================================
# TRADING SETTINGS
# =============================================================================
DEFAULT_RISK_PERCENT=1.0
MAX_RISK_PERCENT=5.0
DEFAULT_SLIPPAGE=3
MAX_SPREAD=5
MAGIC_NUMBER=123456
ENABLE_LIVE_TRADING=False

# =============================================================================
# RISK MANAGEMENT
# =============================================================================
MAX_DRAWDOWN_PERCENT=10.0
MAX_DAILY_LOSS_PERCENT=3.0
MAX_POSITIONS=10
CORRELATION_LIMIT=0.7

# =============================================================================
# DATA SETTINGS
# =============================================================================
DATA_UPDATE_INTERVAL=1
HISTORY_DAYS=30
CACHE_DURATION=300

# =============================================================================
# STRATEGY SETTINGS
# =============================================================================
MAX_STRATEGIES_PER_USER=10
BACKTEST_MAX_DAYS=365
OPTIMIZATION_MAX_ITERATIONS=1000
ENABLE_PAPER_TRADING=True

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FINANCIAL_MODELING_PREP_API_KEY=your_fmp_key
TWELVE_DATA_API_KEY=your_twelve_data_key
TRADINGVIEW_API_KEY=your_tradingview_key

# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================
ENABLE_EMAIL_NOTIFICATIONS=False
ENABLE_WEBHOOK_NOTIFICATIONS=False
WEBHOOK_URL=https://your-webhook-url.com/notify
EMAIL_RECIPIENTS=trader@example.com,admin@example.com

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_password

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
SENTRY_DSN=your_sentry_dsn_url
LOG_LEVEL=INFO

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================
DJANGO_SETTINGS_MODULE=defang_sample.settings
PYTHONPATH=/app